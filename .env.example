# ==========================================
# ANYCAST DNS CLUSTER SETTINGS
# ==========================================

# The Shared IP for the entire cluster (e.g., 10.0.0.53)
ANYCAST_IP=10.0.0.53

# The physical IP of THIS node (e.g., 192.168.1.10)
NODE_IP=192.168.1.x

# The physical interface name (e.g., eth0, ens18, or enp0s3)
# Check this by running 'ip a' on your host.
IFACE=eth0

# ==========================================
# ADGUARD HOME CREDENTIALS
# ==========================================
ADGUARD_USER=admin
ADGUARD_PASS=CHANGE_ME_TO_SOMETHING_SECURE

# ==========================================
# SYNC SETTINGS (For Multi-Node)
# ==========================================
# The IP of your "Master" AdGuard instance. 
# Slaves will pull their config from here.
MASTER_IP=192.168.1.x